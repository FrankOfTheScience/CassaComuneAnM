<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Color x:Key="Primary">#04884A</Color>
    <Color x:Key="PrimaryHover">#A1D078</Color>
    <Color x:Key="Surface">#FFFFFF</Color>
    <Color x:Key="SurfaceAlt">#F6FBF7</Color>
    <Color x:Key="Ink">#242626</Color>
    <Color x:Key="InkMuted">#5E6661</Color>
    <Color x:Key="Border">#D7E6DA</Color>
    <Color x:Key="BorderStrong">#99BCA0</Color>
    <Color x:Key="Danger">#B3261E</Color>
    <Color x:Key="DangerSoft">#FDECEA</Color>
    <Color x:Key="White">#FFFFFF</Color>
    <Color x:Key="Black">#242626</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}" />
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="{StaticResource PrimaryHover}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="{StaticResource SurfaceAlt}" />
    <SolidColorBrush x:Key="InkBrush" Color="{StaticResource Ink}" />
    <SolidColorBrush x:Key="InkMutedBrush" Color="{StaticResource InkMuted}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource Border}" />
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrong}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource Danger}" />
    <SolidColorBrush x:Key="DangerSoftBrush" Color="{StaticResource DangerSoft}" />
</ResourceDictionary>
