<?xml version="1.0" encoding="UTF-8" ?>
<?xaml-comp compile="true" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="Padding" Value="0" />
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
    </Style>

    <Style TargetType="NavigationPage">
        <Setter Property="BarBackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="BarTextColor" Value="{StaticResource Ink}" />
        <Setter Property="IconColor" Value="{StaticResource Primary}" />
    </Style>

    <Style TargetType="Shell" ApplyToDerivedTypes="True">
        <Setter Property="Shell.BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="Shell.ForegroundColor" Value="{StaticResource Ink}" />
        <Setter Property="Shell.TitleColor" Value="{StaticResource Ink}" />
        <Setter Property="Shell.DisabledColor" Value="{StaticResource BorderStrong}" />
        <Setter Property="Shell.UnselectedColor" Value="{StaticResource InkMuted}" />
        <Setter Property="Shell.NavBarHasShadow" Value="False" />
    </Style>

    <Style TargetType="ActivityIndicator">
        <Setter Property="Color" Value="{StaticResource Primary}" />
    </Style>

    <Style TargetType="Frame">
        <Setter Property="HasShadow" Value="True" />
        <Setter Property="CornerRadius" Value="20" />
        <Setter Property="Padding" Value="18" />
        <Setter Property="Margin" Value="4,4,4,12" />
        <Setter Property="BorderColor" Value="{StaticResource Border}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
        <Setter Property="BackgroundColor" Value="Transparent" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="Label" x:Key="HeroLabel">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="30" />
        <Setter Property="CharacterSpacing" Value="2.4" />
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
    </Style>

    <Style TargetType="Label" x:Key="SectionLabel">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="CharacterSpacing" Value="2.2" />
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
    </Style>

    <Style TargetType="Label" x:Key="CardTitleLabel">
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="CharacterSpacing" Value="1.8" />
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
    </Style>

    <Style TargetType="Label" x:Key="MutedLabel">
        <Setter Property="TextColor" Value="{StaticResource InkMuted}" />
        <Setter Property="FontSize" Value="12" />
    </Style>

    <Style TargetType="Label" x:Key="ValueLabel">
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
    </Style>

    <Style TargetType="Label" x:Key="SecondaryValueLabel">
        <Setter Property="TextColor" Value="{StaticResource InkMuted}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
    </Style>

    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="TextColor" Value="{StaticResource White}" />
        <Setter Property="BackgroundColor" Value="{StaticResource Primary}" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="CharacterSpacing" Value="1.2" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="18,12" />
        <Setter Property="Margin" Value="0,6,0,0" />
        <Setter Property="BorderWidth" Value="0" />
        <Setter Property="MinimumHeightRequest" Value="48" />
        <Setter Property="MinimumWidthRequest" Value="48" />
        <Setter Property="VisualStateManager.VisualStateGroups">
            <VisualStateGroupList>
                <VisualStateGroup x:Name="CommonStates">
                    <VisualState x:Name="Normal" />
                    <VisualState x:Name="PointerOver">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource PrimaryHover}" />
                            <Setter Property="TextColor" Value="{StaticResource Ink}" />
                            <Setter Property="BorderColor" Value="{StaticResource Primary}" />
                        </VisualState.Setters>
                    </VisualState>
                    <VisualState x:Name="Disabled">
                        <VisualState.Setters>
                            <Setter Property="BackgroundColor" Value="{StaticResource Border}" />
                            <Setter Property="TextColor" Value="{StaticResource InkMuted}" />
                        </VisualState.Setters>
                    </VisualState>
                </VisualStateGroup>
            </VisualStateGroupList>
        </Setter>
    </Style>

    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}" />

    <Style TargetType="Button" x:Key="SecondaryButton" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
        <Setter Property="BorderColor" Value="{StaticResource Primary}" />
        <Setter Property="BorderWidth" Value="1" />
    </Style>

    <Style TargetType="Button" x:Key="TertiaryButton" BasedOn="{StaticResource PrimaryButton}">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceAlt}" />
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
        <Setter Property="BorderColor" Value="{StaticResource BorderStrong}" />
        <Setter Property="BorderWidth" Value="1" />
    </Style>

    <Style TargetType="Entry">
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceAlt}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource InkMuted}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinimumHeightRequest" Value="48" />
        <Setter Property="Margin" Value="0,6,0,0" />
    </Style>

    <Style TargetType="Picker">
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
        <Setter Property="TitleColor" Value="{StaticResource InkMuted}" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceAlt}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinimumHeightRequest" Value="48" />
    </Style>

    <Style TargetType="DatePicker">
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceAlt}" />
        <Setter Property="FontFamily" Value="OpenSansRegular" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="MinimumHeightRequest" Value="48" />
        <Setter Property="Margin" Value="0,4,0,0" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Color" Value="{StaticResource Primary}" />
        <Setter Property="MinimumHeightRequest" Value="44" />
        <Setter Property="MinimumWidthRequest" Value="44" />
    </Style>

    <Style TargetType="Border">
        <Setter Property="Stroke" Value="{StaticResource Border}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="StrokeShape" Value="RoundRectangle 18" />
    </Style>

    <Style TargetType="Label" x:Key="DialogMessageLabel">
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
        <Setter Property="FontSize" Value="15" />
        <Setter Property="LineBreakMode" Value="WordWrap" />
    </Style>

    <Style TargetType="Border" x:Key="FieldShell">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceAlt}" />
        <Setter Property="Stroke" Value="{StaticResource BorderStrong}" />
        <Setter Property="StrokeThickness" Value="1" />
        <Setter Property="Padding" Value="14,10" />
        <Setter Property="Margin" Value="0,6,0,0" />
        <Setter Property="StrokeShape" Value="RoundRectangle 18" />
    </Style>

    <Style TargetType="Label" x:Key="FieldLabel">
        <Setter Property="TextColor" Value="{StaticResource InkMuted}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="CharacterSpacing" Value="1.4" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
    </Style>

    <Style TargetType="Label" x:Key="ValidationLabel">
        <Setter Property="TextColor" Value="{StaticResource Primary}" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
    </Style>

    <Style TargetType="Label" x:Key="DangerLabel">
        <Setter Property="TextColor" Value="{StaticResource Danger}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
    </Style>

    <Style TargetType="Frame" x:Key="DangerFrame">
        <Setter Property="BackgroundColor" Value="{StaticResource DangerSoft}" />
        <Setter Property="BorderColor" Value="{StaticResource Danger}" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="HasShadow" Value="True" />
    </Style>

    <Style TargetType="Frame" x:Key="MetricCardFrame">
        <Setter Property="BackgroundColor" Value="{StaticResource Surface}" />
        <Setter Property="BorderColor" Value="{StaticResource BorderStrong}" />
        <Setter Property="CornerRadius" Value="18" />
        <Setter Property="Padding" Value="16" />
        <Setter Property="Margin" Value="4,4,4,12" />
        <Setter Property="HasShadow" Value="True" />
    </Style>

    <Style TargetType="Frame" x:Key="ListCardFrame" BasedOn="{StaticResource MetricCardFrame}">
        <Setter Property="BackgroundColor" Value="{StaticResource SurfaceAlt}" />
        <Setter Property="Padding" Value="16" />
    </Style>

    <Style TargetType="Label" x:Key="MetricCaptionLabel">
        <Setter Property="TextColor" Value="{StaticResource InkMuted}" />
        <Setter Property="FontSize" Value="11" />
        <Setter Property="CharacterSpacing" Value="1.3" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
    </Style>

    <Style TargetType="Label" x:Key="MetricValueLabel">
        <Setter Property="TextColor" Value="{StaticResource Ink}" />
        <Setter Property="FontSize" Value="22" />
        <Setter Property="FontFamily" Value="OpenSansSemibold" />
    </Style>

    <Style TargetType="Grid" x:Key="ProgressTrack">
        <Setter Property="HeightRequest" Value="12" />
        <Setter Property="BackgroundColor" Value="{StaticResource PrimarySoft}" />
        <Setter Property="Margin" Value="0,8,0,0" />
    </Style>
</ResourceDictionary>
