<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CassaComuneAnM.MauiAppUi.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Cassa Comune">
    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="18">
            <Label FontAttributes="Bold" FontSize="28" Text="Cassa Comune AnM" />
            <Label
                FontSize="16"
                Text="Frontend MAUI per la gestione di viaggi, partecipanti, spese e versamenti." />

            <Frame BackgroundColor="#F5F7FA" BorderColor="#D9E2EC" CornerRadius="18" Padding="20">
                <VerticalStackLayout Spacing="12">
                    <Label FontAttributes="Bold" FontSize="20" Text="Operazioni disponibili" />
                    <Button Command="{Binding ShowTripsCommand}" Text="Apri lista viaggi" />
                    <Button Command="{Binding CreateTripCommand}" Text="Crea nuovo viaggio" />
                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
