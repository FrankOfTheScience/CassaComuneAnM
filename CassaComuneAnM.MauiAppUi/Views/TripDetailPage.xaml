<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CassaComuneAnM.MauiAppUi.Views.TripDetailPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Dettaglio viaggio">
    <ContentPage.ToolbarItems>
        <ToolbarItem Command="{Binding EditTripCommand}" IsEnabled="{Binding IsNotBusy}" Text="MODIFICA" />
        <ToolbarItem Command="{Binding DeleteTripCommand}" IsEnabled="{Binding IsNotBusy}" Text="ELIMINA" />
    </ContentPage.ToolbarItems>
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="16">
            <Frame BackgroundColor="{StaticResource SurfaceAlt}" BorderColor="{StaticResource BorderStrong}" CornerRadius="20">
                <VerticalStackLayout Spacing="8">
                    <Label Style="{StaticResource HeroLabel}" FontSize="24" Text="{Binding Trip.TripName, Converter={StaticResource UppercaseConverter}}" />
                    <BoxView HeightRequest="3" HorizontalOptions="Start" WidthRequest="72" Color="{StaticResource Primary}" />
                    <Entry IsVisible="{Binding IsEditingTrip}" Placeholder="Nome viaggio" Text="{Binding Trip.TripName}" />
                    <Label IsVisible="{Binding IsEditingTrip, Converter={StaticResource InverseBooleanConverter}}" Text="{Binding Trip.TripCode, StringFormat='Codice: {0}'}" />
                    <Entry IsVisible="{Binding IsEditingTrip}" Placeholder="Codice viaggio" Text="{Binding Trip.TripCode}" />
                    <DatePicker Date="{Binding Trip.TripDate}" IsVisible="{Binding IsEditingTrip}" />
                    <Label IsVisible="{Binding IsEditingTrip, Converter={StaticResource InverseBooleanConverter}}" Text="{Binding Trip.TripDate, StringFormat='Data: {0:dd/MM/yyyy}'}" />
                    <Label IsVisible="{Binding IsEditingTrip, Converter={StaticResource InverseBooleanConverter}}" Text="{Binding Trip.CoordinatorName, StringFormat='Coordinatore: {0}'}" />
                    <Entry IsVisible="{Binding IsEditingTrip}" Placeholder="Coordinatore" Text="{Binding Trip.CoordinatorName}" />
                    <Label IsVisible="{Binding IsEditingTrip, Converter={StaticResource InverseBooleanConverter}}" Text="{Binding Trip.CashierName, StringFormat='Cassiere: {0}'}" />
                    <Entry IsVisible="{Binding IsEditingTrip}" Placeholder="Cassiere" Text="{Binding Trip.CashierName}" />
                    <Label IsVisible="{Binding IsEditingTrip, Converter={StaticResource InverseBooleanConverter}}" Text="{Binding Trip.Country, StringFormat='Paese: {0}'}" />
                    <Entry IsVisible="{Binding IsEditingTrip}" Placeholder="Paese" Text="{Binding Trip.Country}" />
                    <Label IsVisible="{Binding IsEditingTrip, Converter={StaticResource InverseBooleanConverter}}" Text="{Binding Trip.Currency, StringFormat='Valuta: {0}'}" />
                    <Picker
                        IsVisible="{Binding IsEditingTrip}"
                        Title="Seleziona valuta locale del viaggio"
                        ItemsSource="{Binding SupportedCurrencies}"
                        SelectedItem="{Binding SelectedCurrency}" />
                    <Label IsVisible="{Binding IsEditingTrip, Converter={StaticResource InverseBooleanConverter}}" Text="{Binding Trip.ExchangeRate, StringFormat='Cambio: {0:F4}'}" />
                    <Entry IsVisible="{Binding IsEditingTrip}" Keyboard="Numeric" Placeholder="{Binding ExchangeRatePlaceholder}" Text="{Binding ExchangeRateInput}" />
                    <Label IsVisible="{Binding IsEditingTrip}" Style="{StaticResource MutedLabel}" Text="INSERISCI QUANTA VALUTA LOCALE CORRISPONDE A 1 EUR. ESEMPIO: USD 1,10 SIGNIFICA CHE 1 EUR VALE 1,10 USD." />
                    <HorizontalStackLayout IsVisible="{Binding IsEditingTrip}" Spacing="12">
                        <Button Command="{Binding SaveTripCommand}" IsEnabled="{Binding IsNotBusy}" Text="SALVA VIAGGIO" />
                        <Button Command="{Binding CancelTripEditCommand}" IsEnabled="{Binding IsNotBusy}" Text="ANNULLA" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Frame>
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="12" RowSpacing="12">
                <Frame Grid.Column="0" Padding="14" BackgroundColor="{StaticResource SurfaceAlt}">
                    <VerticalStackLayout>
                        <Label Style="{StaticResource SectionLabel}" FontSize="13" Text="BUDGET TOTALE" />
                        <Label FontSize="20" Text="{Binding Trip.TotalBudget, StringFormat='EUR {0:F2}'}" />
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Column="1" Padding="14" BackgroundColor="{StaticResource SurfaceAlt}">
                    <VerticalStackLayout>
                        <Label Style="{StaticResource SectionLabel}" FontSize="13" Text="VERSATO" />
                        <Label FontSize="20" Text="{Binding Trip.TotalPaid, StringFormat='EUR {0:F2}'}" />
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Row="1" Grid.Column="0" Padding="14" BackgroundColor="{StaticResource SurfaceAlt}">
                    <VerticalStackLayout>
                        <Label Style="{StaticResource SectionLabel}" FontSize="13" Text="SPESE" />
                        <Label FontSize="20" Text="{Binding Trip.TotalExpenses, StringFormat='EUR {0:F2}'}" />
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Row="1" Grid.Column="1" Padding="14" BackgroundColor="{StaticResource SurfaceAlt}">
                    <VerticalStackLayout>
                        <Label Style="{StaticResource SectionLabel}" FontSize="13" Text="SALDO CASSA" />
                        <Label FontSize="20" Text="{Binding Trip.CashBalance, StringFormat='EUR {0:F2}'}" />
                    </VerticalStackLayout>
                </Frame>
            </Grid>

            <Label Style="{StaticResource SectionLabel}" Text="SITUAZIONE CASSA" />
            <CollectionView EmptyView="Nessun partecipante." ItemsSource="{Binding ParticipantSummaries}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,0,0,12" Padding="14" BackgroundColor="{StaticResource SurfaceAlt}">
                            <VerticalStackLayout Spacing="4">
                                <Label Style="{StaticResource CardTitleLabel}" FontSize="16" Text="{Binding Name, Converter={StaticResource UppercaseConverter}}" />
                                <Label Text="{Binding PersonalBudget, StringFormat='Budget: EUR {0:F2}'}" />
                                <Label Text="{Binding TotalPaid, StringFormat='Versato: EUR {0:F2}'}" />
                                <Label Text="{Binding RemainingBudget, StringFormat='Residuo: EUR {0:F2}'}" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <Button Command="{Binding ManageParticipantsCommand}" Text="GESTISCI PARTECIPANTI" />
            <Button Command="{Binding ManageExpensesCommand}" Text="GESTISCI SPESE" />
            <Button Command="{Binding ManageDepositsCommand}" Text="GESTISCI VERSAMENTI" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
