<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CassaComuneAnM.MauiAppUi.Views.DepositPage"
    x:Name="DepositRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Versamenti">
    <ScrollView>
        <VerticalStackLayout Padding="{OnIdiom Phone='16', Tablet='24'}" Spacing="18" MaximumWidthRequest="760" HorizontalOptions="Center">
            <Label Style="{StaticResource HeroLabel}" FontSize="24" Text="VERSAMENTI" />
            <Label Style="{StaticResource MutedLabel}" Text="TIENI TRACCIA DEGLI IMPORTI VERSATI E DEL RESIDUO DISPONIBILE." />

            <Frame Padding="16" BackgroundColor="{StaticResource SurfaceAlt}" BorderColor="{StaticResource BorderStrong}">
                <VerticalStackLayout Spacing="10">
                    <Border Style="{StaticResource FieldShell}">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                            <Label Style="{StaticResource FieldLabel}" Text="PARTECIPANTE" />
                            <Label Grid.Row="1" Text="{Binding SelectedParticipantLabel}" />
                            <Button
                                Grid.Column="1"
                                Grid.RowSpan="2"
                                Command="{Binding SelectParticipantCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Text="SCEGLI" />
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource FieldShell}">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                            <Label Style="{StaticResource FieldLabel}" Text="VALUTA INSERIMENTO" />
                            <Label Grid.Row="1" Text="{Binding SelectedInputCurrencyLabel}" />
                            <Button
                                Grid.Column="1"
                                Grid.RowSpan="2"
                                Command="{Binding SelectInputCurrencyCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Text="CAMBIA" />
                        </Grid>
                    </Border>
                    <Entry Keyboard="Numeric" Placeholder="{Binding AmountPlaceholder}" Text="{Binding AmountInput}" />
                    <Label FontSize="12" Text="{Binding BudgetPreviewText}" TextColor="#52606D" />
                    <Border Style="{StaticResource FieldShell}">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                            <Label Style="{StaticResource FieldLabel}" Text="DATA VERSAMENTO" />
                            <Label Grid.Row="1" Text="{Binding DepositDateDisplay}" />
                            <Button
                                Grid.Column="1"
                                Grid.RowSpan="2"
                                Command="{Binding SelectDepositDateCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Text="DATA" />
                        </Grid>
                    </Border>
                    <Label Style="{StaticResource MutedLabel}" Text="{Binding DepositCoverageText}" />
                    <ProgressBar Progress="{Binding DepositCoverageProgress}" ProgressColor="{StaticResource Primary}" />
                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
                    <Button Command="{Binding AddDepositCommand}" IsEnabled="{Binding IsNotBusy}" Text="{Binding SubmitButtonText}" />
                    <Button Command="{Binding CancelEditCommand}" IsEnabled="{Binding IsNotBusy}" IsVisible="{Binding IsEditing}" Style="{StaticResource TertiaryButton}" Text="ANNULLA MODIFICA" />
                </VerticalStackLayout>
            </Frame>

            <Label Style="{StaticResource SectionLabel}" Text="STORICO VERSAMENTI" />
            <Grid ColumnDefinitions="1.2*,1.1*,1.3*,1.4*" ColumnSpacing="8" Padding="4,0">
                <Label Style="{StaticResource FieldLabel}" Text="PAGANTE" />
                <Label Grid.Column="1" Style="{StaticResource FieldLabel}" Text="DATA" />
                <Label Grid.Column="2" Style="{StaticResource FieldLabel}" Text="IMPORTO" />
                <Label Grid.Column="3" Style="{StaticResource FieldLabel}" Text="RESIDUO" />
            </Grid>
            <CollectionView EmptyView="Nessun versamento." ItemsSource="{Binding Deposits}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,0,0,12" Padding="14" BackgroundColor="{StaticResource SurfaceAlt}">
                            <VerticalStackLayout Spacing="6">
                                <Label Style="{StaticResource CardTitleLabel}" FontSize="15" Text="{Binding PayerName, Converter={StaticResource UppercaseConverter}}" />
                                <Label Text="{Binding Date, StringFormat='Data: {0:dd/MM/yyyy}'}" />
                                <HorizontalStackLayout Spacing="0" FlexLayout.Wrap="Wrap">
                                    <Label>
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="Importo: " FontAttributes="Bold" />
                                                <Span Text="{Binding AmountPrimaryDisplay}" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                    <Label Style="{StaticResource SecondaryValueLabel}" Text="{Binding AmountSecondaryDisplay}" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="0" FlexLayout.Wrap="Wrap">
                                    <Label>
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="Residuo: " FontAttributes="Bold" />
                                                <Span Text="{Binding RemainingBudgetPrimaryDisplay}" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                    <Label Style="{StaticResource SecondaryValueLabel}" Text="{Binding RemainingBudgetSecondaryDisplay}" />
                                </HorizontalStackLayout>
                                <Button
                                    Command="{Binding Source={x:Reference DepositRoot}, Path=BindingContext.StartEditDepositCommand}"
                                    CommandParameter="{Binding .}"
                                    IsEnabled="{Binding Source={x:Reference DepositRoot}, Path=BindingContext.IsNotBusy}"
                                    Style="{StaticResource SecondaryButton}"
                                    Text="MODIFICA VERSAMENTO" />
                                <Button
                                    Command="{Binding Source={x:Reference DepositRoot}, Path=BindingContext.DeleteDepositCommand}"
                                    CommandParameter="{Binding .}"
                                    IsEnabled="{Binding Source={x:Reference DepositRoot}, Path=BindingContext.IsNotBusy}"
                                    Style="{StaticResource TertiaryButton}"
                                    Text="ELIMINA VERSAMENTO" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
