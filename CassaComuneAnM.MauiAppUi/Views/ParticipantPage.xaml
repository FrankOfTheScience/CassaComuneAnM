<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CassaComuneAnM.MauiAppUi.Views.ParticipantPage"
    x:Name="ParticipantRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Partecipanti">
    <Grid Padding="{OnIdiom Phone='16', Tablet='24'}" RowDefinitions="Auto,*" RowSpacing="20" MaximumWidthRequest="760" HorizontalOptions="Center">
        <Frame Padding="16">
            <VerticalStackLayout Spacing="10">
                <Entry Placeholder="Nome partecipante" Text="{Binding ParticipantName}" />
                <Entry Keyboard="Numeric" Placeholder="{Binding PersonalBudgetPlaceholder}" Text="{Binding PersonalBudgetInput}" />
                <Button Command="{Binding AddParticipantCommand}" Text="Aggiungi partecipante" />
            </VerticalStackLayout>
        </Frame>

        <CollectionView Grid.Row="1" EmptyView="Nessun partecipante." ItemsSource="{Binding Participants}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,0,0,12" Padding="14">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                            <Label FontAttributes="Bold" Text="{Binding Name}" />
                            <Button
                                Grid.Column="1"
                                Command="{Binding Source={x:Reference ParticipantRoot}, Path=BindingContext.RemoveParticipantCommand}"
                                CommandParameter="{Binding .}"
                                Style="{StaticResource TertiaryButton}"
                                Text="Rimuovi" />
                            <HorizontalStackLayout Grid.Row="1" Spacing="0" FlexLayout.Wrap="Wrap">
                                <Label>
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="Budget: " FontAttributes="Bold" />
                                            <Span Text="{Binding BudgetPrimaryDisplay}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label Style="{StaticResource SecondaryValueLabel}" Text="{Binding BudgetSecondaryDisplay}" />
                            </HorizontalStackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
