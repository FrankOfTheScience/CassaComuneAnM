<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CassaComuneAnM.MauiAppUi.Views.CreateTripPage"
    x:Name="CreateTripRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Nuovo viaggio">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">
            <Label Style="{StaticResource HeroLabel}" FontSize="24" Text="NUOVO VIAGGIO" />
            <Label Style="{StaticResource MutedLabel}" Text="COMPILA I DATI PRINCIPALI E PREPARA I PARTECIPANTI INIZIALI." />
            <Entry Placeholder="Nome viaggio" Text="{Binding TripName}" />
            <Entry Placeholder="Codice viaggio" Text="{Binding TripCode}" />
            <DatePicker Date="{Binding TripDate}" />
            <Entry Placeholder="Nome coordinatore" Text="{Binding CoordinatorName}" />
            <Entry Placeholder="Codice coordinatore" Text="{Binding CoordinatorCode}" />
            <Entry Placeholder="Nome cassiere" Text="{Binding CashierName}" />
            <Entry Placeholder="Paese del viaggio" Text="{Binding Country}" />
            <Picker
                Title="Seleziona valuta locale del viaggio"
                ItemsSource="{Binding SupportedCurrencies}"
                SelectedItem="{Binding SelectedCurrency}" />
            <Entry Keyboard="Numeric" Placeholder="{Binding ExchangeRatePlaceholder}" Text="{Binding ExchangeRateInput}" />
            <Label Style="{StaticResource MutedLabel}" Text="INSERISCI QUANTA VALUTA LOCALE CORRISPONDE A 1 EUR. ESEMPIO: USD 1,10 SIGNIFICA CHE 1 EUR VALE 1,10 USD." />
            <Entry Keyboard="Numeric" Placeholder="Budget base in EUR per ciascun partecipante del viaggio" Text="{Binding BudgetPerPaxInput}" />
            <Label Style="{StaticResource MutedLabel}" Text="QUESTO È IL BUDGET STANDARD CHE IL SISTEMA APPLICA AI PARTECIPANTI, SALVO OVERRIDE MANUALE." />

            <Frame Padding="16" BackgroundColor="{StaticResource SurfaceAlt}" BorderColor="{StaticResource BorderStrong}">
                <VerticalStackLayout Spacing="10">
                    <Label Style="{StaticResource SectionLabel}" Text="PARTECIPANTI INIZIALI" />
                    <Entry Placeholder="Nome partecipante" Text="{Binding ParticipantName}" />
                    <Entry Keyboard="Numeric" Placeholder="Budget personale in EUR del singolo partecipante, vuoto = usa il budget base" Text="{Binding ParticipantBudgetInput}" />
                    <Label Style="{StaticResource MutedLabel}" Text="USA QUESTO CAMPO SOLO SE QUEL PARTECIPANTE DEVE AVERE UN BUDGET DIVERSO DAL BUDGET BASE DEL VIAGGIO." />
                    <Button Command="{Binding AddParticipantCommand}" IsEnabled="{Binding IsNotBusy}" Text="AGGIUNGI PARTECIPANTE" />

                    <CollectionView EmptyView="Nessun partecipante iniziale." ItemsSource="{Binding Participants}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Frame Margin="0,0,0,10" Padding="12" BackgroundColor="{StaticResource Surface}">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                                        <Label Style="{StaticResource CardTitleLabel}" FontSize="15" Text="{Binding Name, Converter={StaticResource UppercaseConverter}}" />
                                        <Button
                                            Grid.Column="1"
                                            Command="{Binding Source={x:Reference CreateTripRoot}, Path=BindingContext.RemoveParticipantCommand}"
                                            CommandParameter="{Binding .}"
                                            IsEnabled="{Binding Source={x:Reference CreateTripRoot}, Path=BindingContext.IsNotBusy}"
                                            Text="RIMUOVI" />
                                        <Label Grid.Row="1" Text="{Binding PersonalBudget, StringFormat='Budget: EUR {0:F2}'}" />
                                    </Grid>
                                </Frame>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>
            </Frame>

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
            <Button Command="{Binding SaveTripCommand}" IsEnabled="{Binding IsNotBusy}" Text="SALVA VIAGGIO" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
