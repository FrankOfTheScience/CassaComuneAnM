<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CassaComuneAnM.MauiAppUi.Views.TripListPage"
    x:Name="TripListRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:converters="clr-namespace:CassaComuneAnM.MauiAppUi.Converters"
    Title="Viaggi">
    <Grid Padding="{OnIdiom Phone='16', Tablet='24'}" RowDefinitions="Auto,*" RowSpacing="18" MaximumWidthRequest="760" HorizontalOptions="Center">
        <VerticalStackLayout Spacing="8">
            <Label Style="{StaticResource HeroLabel}" FontSize="24" Text="VIAGGI" />
            <Label Style="{StaticResource MutedLabel}" Text="ARCHIVIO DEI VIAGGI GESTITI DALLA CASSA COMUNE." />
            <Button Command="{Binding CreateTripCommand}" HorizontalOptions="Start" Style="{StaticResource SecondaryButton}" Text="NUOVO VIAGGIO" />
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" EmptyView="Nessun viaggio salvato." ItemsSource="{Binding Trips}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,0,0,14" Padding="16" BackgroundColor="{StaticResource SurfaceAlt}" BorderColor="{StaticResource BorderStrong}">
                        <VerticalStackLayout Spacing="8">
                            <Label Style="{StaticResource CardTitleLabel}" Text="{Binding TripName, Converter={StaticResource UppercaseConverter}}" />
                            <Label Text="{Binding TripCode, StringFormat='Codice: {0}'}" />
                            <Label Text="{Binding TripDate, StringFormat='Data: {0:dd/MM/yyyy}'}" />
                            <Label Text="{Binding Country, StringFormat='Paese: {0}'}" />
                            <Button
                                Command="{Binding Source={x:Reference TripListRoot}, Path=BindingContext.OpenTripCommand}"
                                CommandParameter="{Binding .}"
                                Text="APRI DETTAGLIO" />
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </Grid>
</ContentPage>
