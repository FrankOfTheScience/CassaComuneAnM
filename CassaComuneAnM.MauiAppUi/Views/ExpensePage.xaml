<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CassaComuneAnM.MauiAppUi.Views.ExpensePage"
    x:Name="ExpenseRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Spese">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="18">
            <Label Style="{StaticResource HeroLabel}" FontSize="24" Text="SPESE" />
            <Label Style="{StaticResource MutedLabel}" Text="REGISTRA, MODIFICA E CONTROLLA LE SPESE DEL VIAGGIO." />

            <Frame Padding="16" BackgroundColor="{StaticResource SurfaceAlt}" BorderColor="{StaticResource BorderStrong}">
                <VerticalStackLayout Spacing="10">
                    <Entry Placeholder="Descrizione spesa" Text="{Binding Description}" />
                    <Entry Keyboard="Numeric" Placeholder="Importo spesa in EUR" Text="{Binding AmountInput}" />
                    <DatePicker Date="{Binding ExpenseDate}" />
                    <HorizontalStackLayout Spacing="12">
                        <CheckBox IsChecked="{Binding TourLeaderFree}" />
                        <Label VerticalTextAlignment="Center" Text="Tour leader gratuito" />
                    </HorizontalStackLayout>
                    <Label FontSize="12" Text="{Binding HelperText}" TextColor="#52606D" />

                    <Label Style="{StaticResource SectionLabel}" FontSize="13" Text="ESCLUDI PARTECIPANTI DAL BENEFICIO" />
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Participants}" Spacing="8">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <HorizontalStackLayout Spacing="12">
                                    <CheckBox IsChecked="{Binding IsSelected}" />
                                    <Label VerticalTextAlignment="Center" Text="{Binding Name}" />
                                </HorizontalStackLayout>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
                    <Button Command="{Binding AddExpenseCommand}" IsEnabled="{Binding IsNotBusy}" Text="{Binding SubmitButtonText}" />
                    <Button Command="{Binding CancelEditCommand}" IsEnabled="{Binding IsNotBusy}" IsVisible="{Binding IsEditing}" Text="ANNULLA MODIFICA" />
                </VerticalStackLayout>
            </Frame>

            <Label Style="{StaticResource SectionLabel}" Text="STORICO SPESE" />
            <CollectionView EmptyView="Nessuna spesa." ItemsSource="{Binding Expenses}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Margin="0,0,0,12" Padding="14" BackgroundColor="{StaticResource SurfaceAlt}">
                            <VerticalStackLayout Spacing="6">
                                <Label Style="{StaticResource CardTitleLabel}" FontSize="15" Text="{Binding Description, Converter={StaticResource UppercaseConverter}}" />
                                <Label Text="{Binding Date, StringFormat='Data: {0:dd/MM/yyyy}'}" />
                                <Label Text="{Binding Amount, StringFormat='Importo: EUR {0:F2}'}" />
                                <Label Text="{Binding BeneficiariesText, StringFormat='Beneficiari: {0}'}" />
                                <Button
                                    Command="{Binding Source={x:Reference ExpenseRoot}, Path=BindingContext.StartEditExpenseCommand}"
                                    CommandParameter="{Binding .}"
                                    IsEnabled="{Binding Source={x:Reference ExpenseRoot}, Path=BindingContext.IsNotBusy}"
                                    Text="MODIFICA SPESA" />
                                <Button
                                    Command="{Binding Source={x:Reference ExpenseRoot}, Path=BindingContext.DeleteExpenseCommand}"
                                    CommandParameter="{Binding .}"
                                    IsEnabled="{Binding Source={x:Reference ExpenseRoot}, Path=BindingContext.IsNotBusy}"
                                    Text="ELIMINA SPESA" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
