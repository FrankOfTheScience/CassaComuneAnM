<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CassaComuneAnM.MauiAppUi.Views.ExpensePage"
    x:Name="ExpenseRoot"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Spese">
    <ScrollView>
        <VerticalStackLayout Padding="{OnIdiom Phone='18', Tablet='28'}" Spacing="20" MaximumWidthRequest="760" HorizontalOptions="Center">
            <Label Style="{StaticResource HeroLabel}" FontSize="24" Text="SPESE" />
            <Label Style="{StaticResource MutedLabel}" Text="REGISTRA, MODIFICA E CONTROLLA LE SPESE DEL VIAGGIO." />

            <Frame Style="{StaticResource MetricCardFrame}" Padding="16" BackgroundColor="{StaticResource SurfaceAlt}" BorderColor="{StaticResource BorderStrong}">
                <VerticalStackLayout Spacing="10">
                    <Entry Placeholder="Descrizione spesa" Text="{Binding Description}" />
                    <Border Style="{StaticResource FieldShell}">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                            <Label Style="{StaticResource FieldLabel}" Text="VALUTA INSERIMENTO" />
                            <Label Grid.Row="1" Text="{Binding SelectedInputCurrencyLabel}" />
                            <Button
                                Grid.Column="1"
                                Grid.RowSpan="2"
                                Command="{Binding SelectInputCurrencyCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Text="CAMBIA" />
                        </Grid>
                    </Border>
                    <Entry Keyboard="Numeric" Placeholder="{Binding AmountPlaceholder}" Text="{Binding AmountInput}" />
                    <Border Style="{StaticResource FieldShell}">
                        <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto">
                            <Label Style="{StaticResource FieldLabel}" Text="DATA SPESA" />
                            <Label Grid.Row="1" Text="{Binding ExpenseDateDisplay}" />
                            <Button
                                Grid.Column="1"
                                Grid.RowSpan="2"
                                Command="{Binding SelectExpenseDateCommand}"
                                Style="{StaticResource SecondaryButton}"
                                Text="DATA" />
                        </Grid>
                    </Border>
                    <HorizontalStackLayout Spacing="12">
                        <CheckBox IsChecked="{Binding TourLeaderFree}" />
                        <Label VerticalTextAlignment="Center" Text="Tour leader gratuito" />
                    </HorizontalStackLayout>
                    <Label FontSize="12" Text="{Binding HelperText}" TextColor="#52606D" />
                    <Frame Style="{StaticResource ListCardFrame}" Padding="14">
                        <VerticalStackLayout Spacing="6">
                            <Grid ColumnDefinitions="*,Auto">
                                <Label Style="{StaticResource SectionLabel}" FontSize="13" Text="SATURAZIONE SPESE" />
                                <Label Grid.Column="1" Style="{StaticResource MetricCaptionLabel}" Text="{Binding ExpenseCoverageProgress, StringFormat='{0:P0}'}" />
                            </Grid>
                            <Label Style="{StaticResource MutedLabel}" Text="{Binding ExpenseCoverageText}" />
                            <Grid Style="{StaticResource ProgressTrack}">
                                <ProgressBar Progress="{Binding ExpenseCoverageProgress}" ProgressColor="{StaticResource Primary}" />
                            </Grid>
                        </VerticalStackLayout>
                    </Frame>

                    <Label Style="{StaticResource SectionLabel}" FontSize="13" Text="ESCLUDI PARTECIPANTI DAL BENEFICIO" />
                    <VerticalStackLayout BindableLayout.ItemsSource="{Binding Participants}" Spacing="8">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <HorizontalStackLayout Spacing="12">
                                    <CheckBox IsChecked="{Binding IsSelected}" />
                                    <Label VerticalTextAlignment="Center" Text="{Binding Name}" />
                                </HorizontalStackLayout>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>

                    <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
                    <Button Command="{Binding AddExpenseCommand}" IsEnabled="{Binding IsNotBusy}" Text="{Binding SubmitButtonText}" />
                    <Button Command="{Binding CancelEditCommand}" IsEnabled="{Binding IsNotBusy}" IsVisible="{Binding IsEditing}" Style="{StaticResource TertiaryButton}" Text="ANNULLA MODIFICA" />
                </VerticalStackLayout>
            </Frame>

            <Label Style="{StaticResource SectionLabel}" Text="STORICO SPESE" />
            <Label Style="{StaticResource MutedLabel}" Text="Vista storica a card con dettaglio rapido di importo e beneficiari." />
            <CollectionView EmptyView="Nessuna spesa." ItemsSource="{Binding Expenses}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame Style="{StaticResource ListCardFrame}">
                            <VerticalStackLayout Spacing="6">
                                <Label Style="{StaticResource CardTitleLabel}" FontSize="15" Text="{Binding Description, Converter={StaticResource UppercaseConverter}}" />
                                <Label Text="{Binding Date, StringFormat='Data: {0:dd/MM/yyyy}'}" />
                                <HorizontalStackLayout Spacing="0" FlexLayout.Wrap="Wrap">
                                    <Label>
                                        <Label.FormattedText>
                                            <FormattedString>
                                                <Span Text="Importo: " FontAttributes="Bold" />
                                                <Span Text="{Binding AmountPrimaryDisplay}" />
                                            </FormattedString>
                                        </Label.FormattedText>
                                    </Label>
                                    <Label Style="{StaticResource SecondaryValueLabel}" Text="{Binding AmountSecondaryDisplay}" />
                                </HorizontalStackLayout>
                                <Label Text="{Binding BeneficiariesText, StringFormat='Beneficiari: {0}'}" />
                                <Button
                                    Command="{Binding Source={x:Reference ExpenseRoot}, Path=BindingContext.StartEditExpenseCommand}"
                                    CommandParameter="{Binding .}"
                                    IsEnabled="{Binding Source={x:Reference ExpenseRoot}, Path=BindingContext.IsNotBusy}"
                                    Style="{StaticResource SecondaryButton}"
                                    Text="MODIFICA SPESA" />
                                <Button
                                    Command="{Binding Source={x:Reference ExpenseRoot}, Path=BindingContext.DeleteExpenseCommand}"
                                    CommandParameter="{Binding .}"
                                    IsEnabled="{Binding Source={x:Reference ExpenseRoot}, Path=BindingContext.IsNotBusy}"
                                    Style="{StaticResource TertiaryButton}"
                                    Text="ELIMINA SPESA" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
